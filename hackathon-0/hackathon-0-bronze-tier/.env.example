# AI Employee Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# System Configuration
# ===========================================

# Run in development mode (no real actions)
DEV_MODE=true

# Dry run mode (log actions but don't execute)
DRY_RUN=true

# Vault path (Obsidian)
VAULT_PATH=./Vault

# ===========================================
# Polling Intervals (seconds)
# ===========================================

GMAIL_POLL_INTERVAL=60
WHATSAPP_POLL_INTERVAL=30
ORCHESTRATOR_CHECK_INTERVAL=30
WATCHDOG_CHECK_INTERVAL=30

# ===========================================
# MCP Server Configuration
# ===========================================

MCP_PORT=8808

# ===========================================
# Gmail API Configuration
# ===========================================
# Get credentials from: https://console.cloud.google.com/

GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080

# ===========================================
# WhatsApp Configuration
# ===========================================
# WhatsApp Web uses browser automation (Playwright)
# No API credentials needed for web version

WHATSAPP_PHONE=  # Optional: for business API

# ===========================================
# Banking/Finance Configuration
# ===========================================

# Bank API credentials (if using API integration)
BANK_API_TOKEN=your_bank_token_here
BANK_API_URL=https://api.yourbank.com

# Payment thresholds (USD)
PAYMENT_AUTO_APPROVE_UNDER=50
PAYMENT_REQUIRE_APPROVAL_OVER=100

# ===========================================
# Email Configuration (SMTP fallback)
# ===========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ===========================================
# Claude Code Configuration
# ===========================================

# Claude Code is configured via ~/.claude/config.json
# No environment variables needed

# ===========================================
# Logging Configuration
# ===========================================

LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90

# ===========================================
# Alert Configuration
# ===========================================

# Email for critical alerts
ALERT_EMAIL=your_email@gmail.com

# Watchdog alert threshold (restarts per hour)
WATCHDOG_ALERT_THRESHOLD=3
